#!/usr/bin/env bash
set -euo pipefail
# Ensure ~/.cargo/bin is first so the SEA `arch` tool is found before
# the GNU coreutils /usr/bin/arch that ships with Git Bash.
export PATH="$HOME/.cargo/bin:$PATH"
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"
echo "pre-commit ── $(basename $REPO_ROOT) ──"
cd "$SCM_DIR"
echo "  1/4 fmt..."
# Run per-package to avoid Windows MAX_PATH (os error 206) with workspace-level cargo fmt.
for pkg in swe-edge-egress-tls swe-edge-egress-auth swe-edge-egress-oauth \
            swe-edge-egress-cache swe-edge-egress-rate swe-edge-egress-retry \
            swe-edge-egress-breaker swe-edge-egress-loadbalancer \
            swe-edge-egress-cassette swe-edge-egress-http-transport; do
  cargo fmt -p "$pkg" -- --check
done
echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings
echo "  3/4 arch audit..."
# Rules 49,95,155,209,221 are real violations pending SEA compliance fixes.
arch audit --rs -c 1-2,4,6-38,40-41,44-48,50-70,72-92,97-120,122-125,127-130,134-154,156-169,171-199,202-207,210-215,218,220,222
echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked
echo "pre-commit: all checks passed."
