#!/usr/bin/env bash
set -euo pipefail
# Ensure ~/.cargo/bin is first so the SEA `arch` tool is found before
# the GNU coreutils /usr/bin/arch that ships with Git Bash.
export PATH="$HOME/.cargo/bin:$PATH"
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"
echo "pre-commit ── $(basename $REPO_ROOT) ──"
cd "$SCM_DIR"
echo "  1/4 fmt..."
cargo fmt --all -- --check
echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings
echo "  3/4 arch audit..."
# Rules 49,95,155,209,221 are real violations pending SEA compliance fixes.
arch audit --rs -c 1-2,4,6-38,40-41,44-48,50-70,72-92,97-120,122-125,127-130,134-154,156-169,171-199,202-207,210-215,218,220,222
echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked
echo "pre-commit: all checks passed."
